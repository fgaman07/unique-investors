generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(uuid())
  userId        String             @unique
  email         String?            @unique
  password      String
  name          String
  mobile        String             @unique
  panNo         String?
  role          UserRole           @default(AGENT)
  status        UserStatus         @default(ACTIVE)
  rank          String             @default("Associate")
  sponsorId     String?
  joiningDate   DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  address       String?
  bankName      String?
  ifscCode      String?
  accountNo     String?
  tdsPercentage Float              @default(5.0)
  awards        Award[]            @relation("UserAwards")
  refreshTokens RefreshToken[]
  commissions   CommissionLedger[]
  sales         Sale[]             @relation("AgentSales")
  sponsor       User?              @relation("SponsorNetwork", fields: [sponsorId], references: [id])
  downline      User[]             @relation("SponsorNetwork")

  @@index([sponsorId])
}

model Project {
  id        String   @id @default(uuid())
  projectNo String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blocks    Block[]
}

model Block {
  id         String     @id @default(uuid())
  name       String
  projectId  String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  properties Property[]

  @@unique([projectId, name])
}

model Property {
  id            String         @id @default(uuid())
  propertyNo    String         @unique
  type          PropertyType
  sizeSqYards   Float
  ratePerSqYard Float
  plc           Float          @default(0)
  totalAmount   Float
  dimension     String?
  status        PropertyStatus @default(PENDING)
  blockId       String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  block         Block          @relation(fields: [blockId], references: [id], onDelete: Cascade)
  sales         Sale[]

  @@index([blockId])
}

model Sale {
  id          String   @id @default(uuid())
  receiptNo   String   @unique
  propertyId  String
  agentId     String
  totalAmount Float
  paidAmount  Float    @default(0)
  saleDate    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  emis        EMI[]
  agent       User     @relation("AgentSales", fields: [agentId], references: [id])
  property    Property @relation(fields: [propertyId], references: [id])

  @@index([agentId])
  @@index([propertyId])
}

model EMI {
  id          String    @id @default(uuid())
  saleId      String
  amount      Float
  paymentDate DateTime?
  status      EmiStatus @default(PENDING)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sale        Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model CommissionLedger {
  id          String       @id @default(uuid())
  userId      String
  amount      Float
  incomeType  String
  paymentMode String?
  remarks     String?
  status      LedgerStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id])

  @@index([userId])
}

model CompanySettings {
  id             String   @id @default(cuid())
  companyName    String
  registrationNo String?
  address        String?
  supportEmail   String?
  contactNumber  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CommissionSetting {
  id         String   @id @default(cuid())
  level      Int      @unique
  label      String
  percentage Float
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Award {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  awardedOn   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("UserAwards", fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([resource, resourceId])
}

model IdempotencyRecord {
  key       String   @id
  payload   Json?
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum PropertyType {
  PLOT
  SHOP
}

enum PropertyStatus {
  PENDING
  BOOKED
}

enum EmiStatus {
  PENDING
  PAID
}

enum LedgerStatus {
  PENDING
  RELEASED
}
